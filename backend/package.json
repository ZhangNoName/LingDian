{
  "name": "lingdian-backend",
  "version": "0.1.0",
  "private": true,
  "description": "LingDian ordering backend powered by NestJS",
  "scripts": {
    "build": "nest build",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:sync-local-config": "node ./scripts/sync-local-config.mjs",
    "db:seed:demo": "node ./scripts/seed-demo-data.mjs",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch"
  },
  "dependencies": {
    "@lingdian/common": "file:../common",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.4.2",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "js-yaml": "^4.1.1",
    "mariadb": "^3.5.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.6",
    "@types/node": "^24.7.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
